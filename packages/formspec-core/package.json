{
  "name": "@formspec-org/core",
  "description": "Core project model, handlers, and invariant layer for Formspec documents",
  "version": "0.1.0",
  "type": "module",
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Formspec-org/formspec.git",
    "directory": "packages/formspec-core"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": ["dist"],
  "scripts": {
    "codegen:component-props": "node ../../scripts/generate-component-schema-props.mjs",
    "build": "npm run codegen:component-props && tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "@formspec-org/engine": "^1.0.0",
    "@formspec-org/types": "^0.1.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
